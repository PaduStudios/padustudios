# Copy to .env and fill in with values from your backend provider.
# The app uses @supabase/supabase-js, so any Supabase-compatible
# backend (Supabase Cloud, self-hosted, etc.) works by swapping these.

# Browser-visible (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only (TanStack server functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
